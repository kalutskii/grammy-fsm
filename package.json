    "esbuild-plugin-tsconfig-paths": "^1.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.61.0"
